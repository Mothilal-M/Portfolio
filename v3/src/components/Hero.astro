---
import Terminal from './Terminal.tsx';
import { site } from '@/data/site';
---

<section
  id="home"
  class="shell relative pb-20 pt-20 md:pb-32 md:pt-28"
  aria-label="Intro"
>
  <p class="mono signal-dot muted text-sm">Open to backend &amp; platform roles</p>

  <div class="mt-10 grid items-start gap-14 md:mt-16 md:grid-cols-[1.2fr_1fr] lg:gap-20">
    {/* ───── Editorial left column ───── */}
    <div>
      <h1 class="font-serif text-display">
        <span class="block overflow-hidden">
          <span class="block hero-rise">{site.shortName}</span>
        </span>
        <span class="muted mx-2 inline-block translate-y-[-0.1em]">—</span>
        <em class="block overflow-hidden italic">
          <span class="block hero-rise hero-rise--delay">{site.tagline.replace(/\.$/, '')}.</span>
        </em>
      </h1>

      <p class="muted mt-8 max-w-prose text-lg leading-relaxed hero-fade">
        <strong class="text-fg">{site.role}</strong> focused on building reliable backend systems
        with <strong class="text-fg">Python</strong>, <strong class="text-fg">FastAPI</strong>, and
        <strong class="text-fg">GCP</strong> at
        <a
          href="https://10xscale.ai"
          target="_blank"
          rel="noopener"
          class="underline decoration-signal/50 underline-offset-4 hover:decoration-signal"
          data-cursor="link"
        >
          10xscale.ai
        </a>. I deliver production-ready APIs, performance improvements, and scalable cloud
        workflows for fast-moving product teams.
      </p>

      <div class="mono mt-10 flex flex-wrap gap-4 text-sm hero-fade hero-fade--delay">
        <a
          href="#work"
          data-cursor="link"
          class="magnetic rounded border border-fg/80 bg-fg px-5 py-3 text-bg transition-colors hover:border-signal hover:bg-signal hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-signal"
        >
          <span>View case studies</span>
          <span aria-hidden="true" class="ml-2">→</span>
        </a>
        <a
          href="#contact"
          data-cursor="link"
          class="magnetic rounded border border-rule/60 px-5 py-3 transition-colors hover:border-signal hover:text-signal focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-signal"
        >
          Hire {site.shortName}
        </a>
        <a
          href={site.socials.linkedin}
          target="_blank"
          rel="noopener"
          data-cursor="link"
          class="magnetic rounded border border-rule/60 px-5 py-3 transition-colors hover:border-signal hover:text-signal focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-signal"
        >
          <span>Résumé</span>
          <span aria-hidden="true" class="ml-2">↗</span>
        </a>
      </div>
    </div>

    {/* ───── Live terminal ───── */}
    <div class="hero-fade hero-fade--delay-long">
      <Terminal client:visible />
    </div>
  </div>

  {/* Scroll indicator */}
  <div
    aria-hidden="true"
    class="mono muted mt-20 hidden items-center gap-3 text-xs uppercase tracking-[0.2em] md:flex"
  >
    <span class="inline-block h-px w-8 bg-current" />
    scroll
  </div>
</section>

<style>
  /* Hero entrance — ink reveal. Reduced-motion is handled by global.css. */
  @keyframes hero-rise {
    from {
      transform: translateY(105%);
    }
    to {
      transform: translateY(0);
    }
  }

  @keyframes hero-fade {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-rise {
    animation: hero-rise 900ms cubic-bezier(0.16, 1, 0.3, 1) 100ms both;
  }
  .hero-rise--delay {
    animation-delay: 260ms;
  }

  .hero-fade {
    animation: hero-fade 900ms cubic-bezier(0.16, 1, 0.3, 1) 600ms both;
  }
  .hero-fade--delay {
    animation-delay: 780ms;
  }
  .hero-fade--delay-long {
    animation-delay: 900ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-rise,
    .hero-fade {
      animation: none;
    }
  }
</style>

<script>
  // Magnetic hover for .magnetic — pointer-position offset.
  const magnets = document.querySelectorAll<HTMLElement>('.magnetic');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    magnets.forEach((el) => {
      el.addEventListener('pointermove', (e) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        el.style.transform = `translate(${x * 0.18}px, ${y * 0.28}px)`;
      });
      el.addEventListener('pointerleave', () => {
        el.style.transform = '';
      });
    });
  }
</script>
